# Copiar a .env.local y completar. NUNCA commitear .env.local.

# Clerk (auth) — keys del dashboard: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Postgres (Prisma CLI la usa vía prisma.config.ts; la app vía driver adapter)
DATABASE_URL=postgresql://user:password@localhost:5432/ensambla
